# Keep secrets, local data, and cruft out of the build context / image.
.git
.gitignore
.dockerignore

venv/
.venv/
env/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/

# Never bake secrets, the local database, or uploaded media into the image.
.env
*.db
*.sqlite
*.sqlite3
instance/
media/

.DS_Store
*.swp
