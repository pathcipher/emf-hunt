# Copy to .env and fill in.  NEVER commit .env — it holds secrets.
#
# Generate a strong secret key with:
#   python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=change-me-to-a-long-random-string

# Database. A relative sqlite path is created under Flask's instance/ folder
# (e.g. instance/emf_hunt.db). The DB holds puzzle answers and player emails,
# so both *.db and instance/ are gitignored.
DATABASE_URL=sqlite:///emf_hunt.db

# Public base URL used to build magic links in emails.
# In docker-compose.prod.yml, this is derived from APP_DOMAIN.
BASE_URL=http://localhost:8000

# --- Production (docker-compose.yml with Traefik) ----
# The domain your app will be served from (e.g. emf-hunt.example.com).
# Used by Traefik to route traffic and obtain Let's Encrypt certs.
APP_DOMAIN=emf-hunt.example.com
# Email for Let's Encrypt cert registration (gets cert renewal notices).
ACME_EMAIL=admin@example.com

# Display name shown across the UI and in emails.
SITE_NAME=Pathcipher@EMF

# Contact info shown in the footer (all optional; leave empty to omit contact section).
CONTACT_NAME=
CONTACT_EMAIL=
CONTACT_PHONE=

# --- Email -----------------------------------------------------------------
# EMAIL_BACKEND = "console"  -> dev: the magic link is printed to the server log
# EMAIL_BACKEND = "ses"      -> AWS SES (requires AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY,
#                               AWS_DEFAULT_REGION env vars)
# EMAIL_BACKEND = "api"      -> other providers: POST to HTTP API (Mailgun, Postmark, Resend, etc.)
EMAIL_BACKEND=console
EMAIL_FROM=EMF Hunt <hunt@example.org>

# AWS SES setup (only for EMAIL_BACKEND=ses):
# Set these in your shell or add to .env:
#   export AWS_ACCESS_KEY_ID=your-key-id
#   export AWS_SECRET_ACCESS_KEY=your-secret-key
#   export AWS_DEFAULT_REGION=us-east-1

# HTTP API setup (only for EMAIL_BACKEND=api):
EMAIL_API_URL=
EMAIL_API_KEY=

# --- Dynamic puzzle content (optional) ----------------------------------------
# Cache duration for dynamic puzzle content fetched from handler URLs (seconds).
# Set to 0 to disable caching.
PUZZLE_CONTENT_CACHE_SECONDS=60

# --- Puzzle media (admin-uploaded images) -------------------------------------
# Where uploaded puzzle images are stored. In Docker this is a mounted volume
# (the compose files set /app/media). Locally it defaults to ./media.
MEDIA_ROOT=
# Max upload / request body size, in megabytes.
MAX_UPLOAD_MB=16

# --- Security --------------------------------------------------------------
# Set to true in production (served over HTTPS) so the session cookie is
# only sent over TLS. Leave false for local http dev.
SESSION_COOKIE_SECURE=false
