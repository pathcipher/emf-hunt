# Copy to .env and fill in.  NEVER commit .env — it holds secrets.
#
# Generate a strong secret key with:
#   python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=change-me-to-a-long-random-string

# Database. A relative sqlite path is created under Flask's instance/ folder
# (e.g. instance/emf_hunt.db). The DB holds puzzle answers and player emails,
# so both *.db and instance/ are gitignored.
DATABASE_URL=sqlite:///emf_hunt.db

# Public base URL used to build magic links in emails.
BASE_URL=http://localhost:8000

# --- Email -----------------------------------------------------------------
# EMAIL_BACKEND = "console"  -> dev: the magic link is printed to the server log
# EMAIL_BACKEND = "api"      -> prod: POST to a third-party email API (Mailgun,
#                               Postmark, Resend, SendGrid, SES, ...)
EMAIL_BACKEND=console
EMAIL_FROM=EMF Hunt <hunt@example.org>

# Only used when EMAIL_BACKEND=api. Shape is provider-generic (see app/email.py).
EMAIL_API_URL=
EMAIL_API_KEY=

# --- Security --------------------------------------------------------------
# Set to true in production (served over HTTPS) so the session cookie is
# only sent over TLS. Leave false for local http dev.
SESSION_COOKIE_SECURE=false
